<Window x:Class="FocusClip.Views.LauncherDock"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <!-- 아이콘 버튼: 투명 배경 + 호버 하이라이트 -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg3Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource NeonBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="6"
            AllowDrop="True" DragOver="Surface_DragOver" Drop="Surface_Drop">
        <Grid>
        <ItemsControl x:Name="AppList">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource IconButton}"
                            Click="AppButton_Click"
                            MouseRightButtonUp="AppButton_RightClick"
                            PreviewMouseLeftButtonDown="AppButton_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="AppButton_PreviewMouseMove"
                            AllowDrop="True" DragOver="AppButton_DragOver" Drop="AppButton_Drop"
                            Tag="{Binding}"
                            ToolTip="{Binding Name}">
                        <Grid Width="24" Height="29">
                            <Image Source="{Binding Icon}" Width="24" Height="24" VerticalAlignment="Top"/>
                            <!-- 활성 표시등 -->
                            <Rectangle Height="2.5" Width="20" RadiusX="1.25" RadiusY="1.25"
                                       VerticalAlignment="Bottom">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Fill" Value="#FF0078D7"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTopMost}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Fill" Value="#FFFF5500"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 고정구간 구분선(FM sepLine) — 코드비하인드에서 위치/표시 갱신 -->
        <Rectangle x:Name="SepLine" Width="2" Fill="#FF555555"
                   HorizontalAlignment="Left" VerticalAlignment="Stretch"
                   Margin="0" Visibility="Collapsed" IsHitTestVisible="False"/>
        </Grid>
    </Border>
</Window>
