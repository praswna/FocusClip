<Window x:Class="FocusClip.Views.Sidebar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="32">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="1,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg3Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource NeonBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0,3">
        <StackPanel Orientation="Vertical">
        <ItemsControl x:Name="AppList">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource IconButton}"
                            Click="AppButton_Click"
                            MouseRightButtonUp="AppButton_RightClick"
                            Tag="{Binding}"
                            ToolTip="{Binding Name}"
                            Margin="0,2">
                        <Grid Width="24" Height="29">
                            <Image Source="{Binding Icon}" Width="24" Height="24" VerticalAlignment="Top"/>
                            <!-- 단축키 번호(고정구간 1~9): 도크와 동일하게 좌상단에 작게 -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Background="#CC000000" CornerRadius="3" Padding="2,0" Margin="-2,-2,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HotkeyLabel}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding HotkeyLabel}" FontSize="8" FontWeight="Bold"
                                           Foreground="White" LineHeight="10" LineStackingStrategy="BlockLineHeight"/>
                            </Border>
                            <Rectangle Height="2.5" Width="20" RadiusX="1.25" RadiusY="1.25"
                                       VerticalAlignment="Bottom">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Fill" Value="#FF0078D7"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTopMost}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Fill" Value="#FFFF5500"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 하단 세로 이동 핸들 (FM의 ::: 핸들) -->
        <Thumb x:Name="MoveHandle" Height="16" Cursor="SizeNS" Margin="2,2,2,1"
               DragDelta="MoveHandle_DragDelta" ToolTip="드래그하여 위/아래로 이동">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent">
                        <TextBlock Text=":::" Foreground="{StaticResource GrayBrush}"
                                   FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        </StackPanel>
    </Border>
</Window>
