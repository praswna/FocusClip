<Window x:Class="FocusClip.Views.ClipboardPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="250" MinWidth="190" MinHeight="120">
    <Window.Resources>
        <!-- 팝업 스크롤바를 다크 테마로(ScrollViewer 내부 스크롤바에 암시적 적용) -->
        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>

        <!-- 카드 삭제(✕) 버튼: 평평, 호버 시 빨강 -->
        <Style x:Key="CardX" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9">
                            <TextBlock Text="✕" FontSize="10" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#66FF3B30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 카드 편집(✎) 버튼 -->
        <Style x:Key="CardEdit" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9">
                            <TextBlock Text="✎" FontSize="11" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 카드 프롬프트 승격(🔖) 버튼: 텍스트 클립을 프롬프트 보관함으로 -->
        <Style x:Key="CardPromote" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9">
                            <TextBlock Text="🔖" FontSize="10" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.7"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 카드 경로열기(📂) 버튼: 저장된 본문 파일 위치를 탐색기로 -->
        <Style x:Key="CardOpen" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9">
                            <TextBlock Text="📂" FontSize="10" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.7"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg3Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 카드 핀(📌) 버튼: 핀 상태면 액센트색 -->
        <Style x:Key="CardPin" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9">
                            <TextBlock Text="📌" FontSize="10" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Opacity="0.55"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg3Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 필터 세그먼트(전체/텍스트/이미지): 선택 시 액센트, 호버 시 Bg3 -->
        <Style x:Key="SegBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="6,2" Margin="0,0,3,0">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg3Brush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource NeonBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 핀 고정 시에만 보이는 이동 핸들(드래그하여 팝업 이동) -->
            <Thumb x:Name="MoveHandle" Grid.Row="0" Height="12" Visibility="Collapsed"
                   Cursor="SizeAll" Margin="0,0,0,3" DragDelta="MoveHandle_DragDelta"
                   ToolTip="드래그하여 이동">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="Transparent">
                            <Rectangle Width="40" Height="3" RadiusX="1.5" RadiusY="1.5"
                                       Fill="{StaticResource GrayBrush}" Opacity="0.6"/>
                        </Border>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 헤더: 필터 세그먼트(전체/텍스트/이미지) + 팝업 핀 토글 -->
            <Grid Grid.Row="1" Height="20" Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="클립보드" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"
                               FontSize="10" VerticalAlignment="Center" Margin="2,0,8,0"/>
                    <RadioButton x:Name="FilterAll" Style="{StaticResource SegBtn}" GroupName="ClipFilter"
                                 Content="전체" IsChecked="True" Checked="Filter_All_Checked"/>
                    <RadioButton x:Name="FilterText" Style="{StaticResource SegBtn}" GroupName="ClipFilter"
                                 Content="텍스트" Checked="Filter_Text_Checked"/>
                    <RadioButton x:Name="FilterImage" Style="{StaticResource SegBtn}" GroupName="ClipFilter"
                                 Content="이미지" Checked="Filter_Image_Checked"/>
                </StackPanel>
                <TextBlock x:Name="FolderCount" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,24,0" FontSize="10" Foreground="{StaticResource GrayBrush}"
                           Cursor="Hand" ToolTip="저장 폴더의 파일 수 (클릭 = 폴더 열기)"
                           MouseLeftButtonUp="FolderCount_Click"/>
                <ToggleButton x:Name="PinToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Width="20" Height="18" Cursor="Hand" ToolTip="팝업 고정(자동 닫힘 해제)"
                              Checked="PinToggle_Changed" Unchecked="PinToggle_Changed">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="pb" Background="Transparent" CornerRadius="9">
                                <TextBlock x:Name="pin" Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="pb" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="pin" Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="pb" Property="Background" Value="{StaticResource Bg3Brush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>

            <ScrollViewer Grid.Row="2" x:Name="Scroller" VerticalScrollBarVisibility="Auto" MaxHeight="320"
                          PreviewMouseWheel="Scroller_PreviewMouseWheel">
                <ItemsControl x:Name="ClipList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Margin="0,2" Padding="6" Cursor="Hand"
                                    MouseLeftButtonUp="Card_Click"
                                    PreviewMouseLeftButtonDown="Card_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="Card_PreviewMouseMove"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Bg2Brush}"/>
                                        <Style.Triggers>
                                            <!-- 핀된 카드: 좌측 액센트 느낌(배경 살짝 강조) -->
                                            <DataTrigger Binding="{Binding Pinned}" Value="True">
                                                <Setter Property="Background" Value="#FF143A37"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Image Grid.Row="0" Source="{Binding Thumb}" Stretch="Uniform"
                                           MaxHeight="88" HorizontalAlignment="Left">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <TextBlock Grid.Row="0" Text="{Binding Snippet}" Foreground="#FFDDDDDD"
                                               TextWrapping="Wrap" MaxHeight="110" TextTrimming="CharacterEllipsis"
                                               Margin="0,0,24,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <StackPanel Grid.Row="0" Orientation="Vertical"
                                                HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <Button Style="{StaticResource CardEdit}" Click="Edit_Click"
                                                Tag="{Binding}" ToolTip="수정"/>
                                        <!-- 프롬프트 승격: 텍스트 클립에만 표시 -->
                                        <Button Click="Promote_Click" Tag="{Binding}" ToolTip="프롬프트로 저장">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource CardPromote}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Style="{StaticResource CardPin}" Click="Pin_Click"
                                                Tag="{Binding}" ToolTip="고정"/>
                                        <Button Style="{StaticResource CardOpen}" Click="Open_Click"
                                                Tag="{Binding}" ToolTip="저장 위치 열기"/>
                                        <Button Style="{StaticResource CardX}" Click="Delete_Click"
                                                Tag="{Binding}" ToolTip="삭제"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Text="{Binding TimeLabel}" Foreground="{StaticResource GrayBrush}"
                                               FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
