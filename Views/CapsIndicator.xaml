<Window x:Class="FocusClip.Views.CapsIndicator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        Width="40" Height="40">
    <!-- 도크와 동일한 톤(BgBrush + 네온 테두리 + 6 라운드). 클릭하면 대소문자 전환. 크기는 도크 높이에 맞춰 코드에서 설정. -->
    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource NeonBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Cursor="Hand"
            MouseLeftButtonUp="Root_Click"
            ToolTip="클릭하여 대소문자(CapsLock) 전환">
        <TextBlock x:Name="Glyph" FontFamily="Segoe UI" FontWeight="Bold" FontSize="20"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
</Window>
