<Window x:Class="FocusClip.Views.PathPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="230" MinWidth="170" MinHeight="80">
    <Window.Resources>
        <!-- 카드 열기(↗) 버튼: 호버 시 액센트 -->
        <Style x:Key="CardOpen" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9">
                            <TextBlock Text="↗" FontSize="11" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 카드 삭제(✕) 버튼: 평평, 호버 시 빨강 -->
        <Style x:Key="CardX" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9">
                            <TextBlock Text="✕" FontSize="10" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#66FF3B30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 필터 세그먼트(전체/로컬/URL): 선택 시 액센트, 호버 시 Bg3 -->
        <Style x:Key="SegBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="6,2" Margin="0,0,3,0">
                            <TextBlock Text="{TemplateBinding Content}" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg3Brush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource NeonBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 필터 세그먼트(전체/로컬/URL) + 팝업 핀 토글 -->
            <Grid Grid.Row="0" Height="20" Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <RadioButton x:Name="FilterAll" Style="{StaticResource SegBtn}" GroupName="PathFilter"
                                 Content="전체" IsChecked="True" Checked="Filter_All_Checked"/>
                    <RadioButton x:Name="FilterLocal" Style="{StaticResource SegBtn}" GroupName="PathFilter"
                                 Content="로컬" Checked="Filter_Local_Checked"/>
                    <RadioButton x:Name="FilterUrl" Style="{StaticResource SegBtn}" GroupName="PathFilter"
                                 Content="URL" Checked="Filter_Url_Checked"/>
                </StackPanel>
                <ToggleButton x:Name="PinToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Width="20" Height="18" Cursor="Hand" ToolTip="팝업 고정(자동 닫힘 해제)"
                              Checked="PinToggle_Changed" Unchecked="PinToggle_Changed">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="pb" Background="Transparent" CornerRadius="9">
                                <TextBlock Text="📌" FontSize="11" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Opacity="0.5"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="pb" Property="Background" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="pb" Property="Background" Value="{StaticResource Bg3Brush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>

            <ScrollViewer Grid.Row="1" x:Name="Scroller" VerticalScrollBarVisibility="Auto" MaxHeight="320"
                          PreviewMouseWheel="Scroller_PreviewMouseWheel">
                <ItemsControl x:Name="PathList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Margin="0,2" Padding="6" Cursor="Hand"
                                    Background="{StaticResource Bg2Brush}"
                                    PreviewMouseLeftButtonDown="Card_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="Card_PreviewMouseMove"
                                    MouseLeftButtonUp="Card_Click"
                                    Tag="{Binding}"
                                    ToolTip="{Binding Text}">
                                <Grid>
                                    <StackPanel Margin="0,0,22,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <!-- 이동/삭제된 로컬 경로는 흐리게 -->
                                                    <DataTrigger Binding="{Binding PathExists}" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="{Binding PathName}" Foreground="#FFDDDDDD"
                                                   FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding PathDir}" Foreground="{StaticResource GrayBrush}"
                                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical"
                                                HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <Button Style="{StaticResource CardOpen}" Click="Open_Click"
                                                Tag="{Binding}" ToolTip="열기"/>
                                        <Button Style="{StaticResource CardX}" Click="Delete_Click"
                                                Tag="{Binding}" ToolTip="삭제"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
